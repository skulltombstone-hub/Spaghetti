<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Spaghetti" parent="android:Theme.Material.NoActionBar">
        <!-- Pinned dark so the Activity window matches the Compose dark theme. Prevents the white flash on cold start AND between NavHost destination transitions. -->
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <style name="Theme.Spaghetti.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Spaghetti</item>
    </style>
</resources>